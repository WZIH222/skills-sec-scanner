{
  "name": "@skills-sec/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the Skills Security Scanner",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
