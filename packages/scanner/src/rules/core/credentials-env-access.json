{
  "id": "credentials-env-access",
  "name": "Detect process.env access",
  "severity": "low",
  "category": "credentials",
  "enabled": true,
  "pattern": {
    "type": "MemberExpression",
    "object": "process",
    "property": "env"
  },
  "message": "process.env access detected - may expose sensitive environment variables",
  "references": [
    "https://nodejs.org/api/process.html#processenv"
  ]
}
