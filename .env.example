# Database Configuration
# Default: SQLite (no server required)
DATABASE_URL="file:./packages/database/prisma/dev.db"

# To use PostgreSQL instead, comment out SQLite above and use:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/skills_sec?schema=public"
# Also change `provider = "sqlite"` to `provider = "postgresql"` in packages/database/prisma/schema.prisma


# Security
JWT_SECRET=your-secret-key-here-at-least-32-chars
ENCRYPTION_KEY=base64-encoded-32-byte-key-for-api-key-encryption
SANDBOX_TIMEOUT=30000
DEFAULT_POLICY=moderate

# Redis (optional - for async folder scanning)
# If not configured, folder scanning will fall back to synchronous mode
# Recommended for folders with 5+ files
REDIS_URL=redis://localhost:6379
# Or leave empty to disable Redis features:
# REDIS_URL=
